# ── Servidor ───────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Banco de Dados ─────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=adaptive_learning
DB_USER=postgres
DB_PASSWORD=sua_senha_aqui

# ── JWT ────────────────────────────────────────────────────
JWT_SECRET=troque_por_string_longa_e_aleatoria_em_producao
JWT_EXPIRES_IN=7d

# ── IA (Groq) ──────────────────────────────────────────────
# Obtenha sua chave gratuita em: https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama3-8b-8192
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Defina como "true" para usar respostas simuladas (sem chave Groq)
AI_MOCK=true

# ── CORS ───────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ── Rate Limiting ──────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
